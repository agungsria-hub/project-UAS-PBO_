@model IEnumerable<SistemRetribusiParkir.Models.LokasiParkir>

@{
    ViewData["Title"] = "Data Lokasi Parkir";
}

<div class="card shadow">

    <div class="card-header d-flex justify-content-between align-items-center">

        <h4 class="mb-0">
            <i class="bi bi-geo-alt-fill"></i>
            Data Lokasi Parkir
        </h4>

        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i>
            Tambah Lokasi
        </a>

    </div>

    <div class="card-body">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show">

                <i class="bi bi-check-circle-fill"></i>

                @TempData["Success"]

                <button type="button" class="btn-close" data-bs-dismiss="alert">
                </button>

            </div>
        }

        <form method="get" class="row mb-3">

            <div class="col-md-4">

                <input type="text" name="search" class="form-control" placeholder="Cari lokasi..."
                       value="@Context.Request.Query["search"]" />

            </div>

            <div class="col-md-2">

                <button class="btn btn-success">
                    <i class="bi bi-search"></i>
                    Cari
                </button>

            </div>

        </form>

        <div class="table-responsive">

            <table id="dataTable" class="table table-bordered table-hover align-middle">

                <thead class="table-dark">

                    <tr>

                        <th width="60">No</th>

                        <th>Nama Lokasi</th>

                        <th>Alamat</th>

                        <th width="120">Kapasitas</th>

                        <th width="120">Status</th>

                        <th width="180">Aksi</th>

                    </tr>

                </thead>

                <tbody>

                    @{
                        int no = 1;
                    }

                    @foreach (var item in Model)
                    {
                        <tr>

                            <td>@no</td>

                            <td>@item.NamaLokasi</td>

                            <td>@item.Alamat</td>

                            <td>@item.Kapasitas</td>

                            <td>

                                @if (item.Status)
                                {
                                    <span class="badge bg-success">
                                        Aktif
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">
                                        Tidak Aktif
                                    </span>
                                }

                            </td>

                            <td>

                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">

                                    <i class="bi bi-pencil-square"></i>

                                </a>

                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm"
                                   onclick="return confirmDelete(event,this)">

                                    <i class="bi bi-trash"></i>

                                </a>

                            </td>

                        </tr>

                        no++;
                    }

                </tbody>

            </table>

        </div>

    </div>

</div>

@section Scripts{

<script>

$(function () {

    let table = $('#dataTable').DataTable({

        responsive: true,

        pageLength: 10,

        columnDefs: [

            {

                targets: 0,

                orderable: false,

                searchable: false

            }

        ],

        language: {

            search: "Cari :",

            lengthMenu: "Tampilkan _MENU_ data",

            zeroRecords: "Data tidak ditemukan",

            info: "Menampilkan _START_ - _END_ dari _TOTAL_ data",

            infoEmpty: "Tidak ada data",

            paginate: {

                first: "Awal",

                last: "Akhir",

                next: "→",

                previous: "←"

            }

        }

    });

    table.on('order.dt search.dt', function () {

        table.column(0, { search: 'applied', order: 'applied' })

             .nodes()

             .each(function (cell, i) {

                 cell.innerHTML = i + 1;

             });

    }).draw();

});

</script>

}
